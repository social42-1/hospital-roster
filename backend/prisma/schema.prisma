generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
}

enum Grade {
  JUNIOR
  SENIOR
}

enum ShiftType {
  MORNING
  NIGHT
  OFF
  WO
  LEAVE
}

enum RosterStatus {
  DRAFT
  PUBLISHED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  grade     Grade?
  shifts    Shift[]
  leaves    Leave[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Roster {
  id        String       @id @default(uuid())
  month     Int
  year      Int
  status    RosterStatus @default(DRAFT)
  shifts    Shift[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([month, year])
}

model Shift {
  id       String    @id @default(uuid())
  rosterId String
  userId   String
  date     DateTime  @db.Date
  type     ShiftType

  roster Roster @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rosterId, userId, date])
}

model Leave {
  id        String      @id @default(uuid())
  userId    String
  date      DateTime    @db.Date
  reason    String
  status    LeaveStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
